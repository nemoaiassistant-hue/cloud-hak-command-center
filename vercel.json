{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dashboard", "destination": "/index.html" }
  ],
  "functions": {
    "api/demos.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=300, stale-while-revalidate=600" }
      ]
    }
  ]
}
